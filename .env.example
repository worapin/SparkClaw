# SparkClaw Environment Variables
# Copy this file to .env and fill in the values

# Database (Neon Postgres)
DATABASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=

# Railway
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=

# Custom Domain Configuration
CUSTOM_DOMAIN_ROOT=sparkclaw.io

# Redis (for BullMQ queue)
REDIS_URL=redis://localhost:6379

# Email (Resend)
RESEND_API_KEY=

# Session
SESSION_SECRET=

# Sentry
SENTRY_DSN=

# PostHog
POSTHOG_API_KEY=

# Prism (LLM Gateway)
PRISM_BASE_URL=
PRISM_API_KEY=

# OpenClaw Template
OPENCLAW_GITHUB_REPO=your-org/openclaw-template

# Admin Configuration
ADMIN_EMAILS=admin@sparkclaw.io
