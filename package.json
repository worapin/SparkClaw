{
  "name": "sparkclaw",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["packages/*"],
  "scripts": {
    "start": "bun run start:api",
    "dev:api": "bun run --filter @sparkclaw/api dev",
    "dev:web": "bun run --filter @sparkclaw/web dev",
    "build": "bun run --filter @sparkclaw/shared build && bun run --filter @sparkclaw/api build && bun run --filter @sparkclaw/web build",
    "start:api": "bun run --filter @sparkclaw/api start",
    "start:web": "bun run --filter @sparkclaw/web preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run packages/shared/src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "bun test --recursive",
    "test:api": "bun test --recursive packages/api",
    "test:shared": "bun test --recursive packages/shared"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
